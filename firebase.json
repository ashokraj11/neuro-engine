{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "firebase-applet-config.json",
      "firebase-blueprint.json",
      "*.log",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}

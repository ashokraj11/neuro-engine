{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "customApiKey": { "type": "string", "description": "User provided Gemini API Key" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "MarketingAsset": {
      "title": "Marketing Asset",
      "description": "A generated marketing asset.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the user who owns the asset." },
        "type": { "type": "string", "description": "The type of the asset (e.g., blog, reel, ads, email, landing, etc.)." },
        "title": { "type": "string", "description": "The title of the asset." },
        "content": { "type": "object", "description": "The content of the asset (can be a map or a list)." },
        "metadata": { "type": "object", "description": "Additional metadata for the asset." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the asset was created." }
      },
      "required": ["userId", "type", "title", "content", "createdAt"]
    },
    "Course": {
      "title": "Learning Course",
      "description": "A course in the learning module.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "targetLink": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "thumbnailUrl", "createdAt"]
    },
    "Tool": {
      "title": "Marketing Tool",
      "description": "An interactive tool in the learning module.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "link": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "icon", "link", "createdAt"]
    },
    "Template": {
      "title": "Resource Template",
      "description": "A downloadable template or PDF.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "size", "downloadUrl", "createdAt"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post for the learning module.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "imageUrl": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "date", "author", "imageUrl", "content", "createdAt"]
    },
    "BrandVoice": {
      "title": "Brand Voice & Customer Avatar DNA",
      "description": "Stores user's brand voice and target customer persona settings.",
      "type": "object",
      "properties": {
        "tone": { "type": "string" },
        "examples": { "type": "string" },
        "productDetails": { "type": "string" },
        "logoUrl": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string", "description": "Persona Name" },
        "description": { "type": "string", "description": "Target Audience Description" },
        "fears": { "type": "string", "description": "Deep-Seated Fears" },
        "desires": { "type": "string", "description": "Secret Desires" },
        "jobsToBeDone": { "type": "string", "description": "Jobs to be Done" },
        "vocabulary": { "type": "string", "description": "Specific Vocabulary" },
        "psychologicalTriggers": { "type": "string", "description": "Psychological Triggers" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AdConfig": {
      "title": "Ad Placement Configuration",
      "description": "Controls the visibility of AdSense placements.",
      "type": "object",
      "properties": {
        "placementId": { "type": "string" },
        "name": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["placementId", "name", "isVisible"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/users/{userId}/settings/brandVoice": {
      "schema": "BrandVoice",
      "description": "User's brand voice and customer avatar settings"
    },
    "/assets/{assetId}": {
      "schema": "MarketingAsset",
      "description": "Collection of all generated marketing assets"
    },
    "/learning/{courseId}": {
      "schema": "Course",
      "description": "Educational courses"
    },
    "/tools/{toolId}": {
      "schema": "Tool",
      "description": "Marketing tools"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Downloadable templates"
    },
    "/blog/{postId}": {
      "schema": "BlogPost",
      "description": "Blog posts"
    },
    "/ad_config/{placementId}": {
      "schema": "AdConfig",
      "description": "Global ad placement settings"
    }
  }
}
